# Relayer proxy
# Request a key from Zama (see README § Configuration). The browser never sees
# this value — it's injected server-side by apps/web/src/app/api/relayer/[chainId]/route.ts.
RELAYER_API_KEY=

# Optional: override the Zama-hosted Sepolia relayer upstream (defaults to
# https://relayer-sepolia.zama.ai). Only set if Zama rotates the host.
# SEPOLIA_RELAYER_URL=
