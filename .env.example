# Relayer proxy — MAINNET ONLY.
#
# The Sepolia testnet relayer (https://relayer.testnet.zama.org/v2) is open and
# needs NO key, so the bounty-judging flow on Sepolia works with zero config.
#
# This key is only required if you wire MAINNET decryption, whose relayer gates
# every request behind x-api-key. It's injected server-side by
# apps/web/src/app/api/relayer/[chainId]/route.ts so the browser never sees it.
# Request a mainnet key at https://forms.gle/jq84zEek1oiv3kBz9 (reviewed by Zama).
RELAYER_API_KEY=

# Optional: override the Zama-hosted mainnet relayer upstream (defaults to
# https://relayer.mainnet.zama.org/v2). Only set if Zama rotates the host.
# MAINNET_RELAYER_URL=
